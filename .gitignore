# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
desktop.ini
claude.MD

# credenciais e chaves - nunca devem ir pro repositorio
*.pem
*.key
*.tfstate
*.tfstate.*
.terraform/

# editores/IDE - configuracao pessoal, nao do time
.vscode/
.idea/
*.swp
*.swo
*~

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# claude code - config local, nao e do time (settings.json compartilhado
# entraria no repo normalmente, so o .local. e pessoal)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# screenshots gerados para uso externo (LinkedIn etc.), nao fazem parte do codigo
/screenshots-linkedin/

# typescript
*.tsbuildinfo
next-env.d.ts
